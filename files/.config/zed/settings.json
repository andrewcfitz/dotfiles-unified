{
  "cli_default_open_behavior": "existing_window",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "csharp": true,
    "dockerfile": true,
    "dracula": true,
    "html": true,
    "toml": true
  },
  "theme": {
    "mode": "system",
    "light": "Dracula",
    "dark": "Dracula"
  },
  "buffer_font_family": "Hack Nerd Font Mono",
  "buffer_font_size": 14,
  "ui_font_size": 14,
  "format_on_save": "on",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  }
}
